# Maintainer: joekamprad <joekamprad at endeavouros.com>

_pkgname=endeavouros-sway-setup
pkgname=eos-settings-sway
pkgver=1.9
pkgrel=1
pkgdesc="pre user creation skel setup for Sway under EndeavourOS"
arch=("any")
url="https://github.com/endeavouros-team/${_pkgname}"
license=("GPL")
depends=('endeavouros-branding' 'eos-sway-tools' 'greetd' 'greetd-tuigreet')
makedepends=("git")
install=eos-settings-sway.install
source=("https://github.com/endeavouros-team/${_pkgname}/archive/refs/tags/${pkgver}.tar.gz")
sha256sums=('3fdeb90d9ea88e95fa79e87a8eb08c021097d032893b998896d2748d98bf3d5b')

package() {
    # Enter the unpacked source directory
    cd "${srcdir}/${_pkgname}-${pkgver}"

    # Create the target directory structure for skel
    mkdir -p "${pkgdir}/etc"
    # Install configuration files to /etc/skel
    cp -a skel "${pkgdir}/etc/skel"

    # Install custom sway start wrapper
    install -Dm755 eos-sway-wrapper "${pkgdir}/usr/bin/eos-sway-wrapper"
    # Install the custom sway session
    install -Dm644 eos-sway.desktop "${pkgdir}/usr/share/wayland-sessions/eos-sway.desktop"

    # Install the license file
    mkdir -p "${pkgdir}/usr/share/licenses/${pkgname}"
    install -Dm644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
