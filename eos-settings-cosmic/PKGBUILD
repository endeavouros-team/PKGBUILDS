pkgname=eos-settings-cosmic
pkgver=1.1
pkgrel=1
pkgdesc="Cosmic settings for EndeavourOS user profiles"
arch=('any')
url="https://github.com/endeavouros-team"
license=('GPL-3.0-or-later')
depends=('glib2' 'endeavouros-theming')
source=('99_eos-settings-cosmic.gschema.override'
        'default'
        'theme'
        'Arc-Dark.ron')
sha256sums=('1c050ad273cad523de06a87f8f66602d8b3ef12259fb5929a74dd1880c03b988'
            '9e57d74c8c974e81b2484378a30d609fade2212632a1ce7ebe43316f033ce450'
            '9e57d74c8c974e81b2484378a30d609fade2212632a1ce7ebe43316f033ce450'
            '436eda4e783c1c3d1fd886a0abb46f5b2939d0ee093da373bffd2402cea4fc88')

package() {
    # GTK GSchema Override (Kein Konflikt mit Upstream)
    install -Dm644 "${srcdir}/99_eos-settings-cosmic.gschema.override" "${pkgdir}/usr/share/glib-2.0/schemas/99_eos-settings-cosmic.gschema.override"

    # COSMIC User-Skel Konfigurationen (Sicher vor Upstream-Dateikonflikten)
    install -Dm644 "${srcdir}/default" "${pkgdir}/etc/skel/.config/cosmic/cosmic-bg/v1/default"
    install -Dm644 "${srcdir}/theme" "${pkgdir}/etc/skel/.config/cosmic/cosmic-theme/v1/theme"
    install -Dm644 "${srcdir}/Arc-Dark.ron" "${pkgdir}/etc/skel/.config/cosmic/cosmic-theme/v1/themes/Arc-Dark.ron"
}