# Maintainer: joekamprad <joekamprad at endeavouros.com>

pkgname=eos-settings-cosmic
pkgver=1.0
pkgrel=7
pkgdesc="Cosmic settings for EndeavourOS user profiles"
arch=('any')
url="https://github.com/endeavouros-team/${pkgname}"
license=('GPL-3.0-or-later')
depends=('endeavouros-branding' 'git')
# Clones directly from the remote GitHub repository using the master branch
source=("${pkgname}::git+${url}.git#branch=master")
sha256sums=('SKIP')

package() {
    local _skel="${pkgdir}/etc/skel/.config"

    install -d "${_skel}"

    # Copy the structures directly from the cloned remote tree
    cp -r "${srcdir}/${pkgname}/cosmic"  "${_skel}/"
    cp -r "${srcdir}/${pkgname}/gtk-3.0" "${_skel}/"
    cp -r "${srcdir}/${pkgname}/gtk-4.0" "${_skel}/"

    # Normalize permissions for the target system
    find "${_skel}" -type d -exec chmod 755 {} +
    find "${_skel}" -type f -exec chmod 644 {} +
}