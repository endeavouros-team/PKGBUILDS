#: ../akm:430
#, sh-printf-format
msgid "Here's information about <i>currently available</i> Linux kernels that are or can be installed."
msgstr "Informace o <i>aktuálně dostupných</i> Linuxových jádrech, která jsou nebo mohou být nainstalována."

#: ../akm:431
#, sh-printf-format
msgid "Install and/or uninstall kernel packages using the checkboxes on the leftmost column."
msgstr "Nainstalujte nebo odinstalujte balíčky jader pomocí zaškrtávacích políček v levém sloupci."

#: ../akm:432
#, sh-printf-format
msgid "<i>Please make sure the system is fully updated when starting <b>%s</b></i>."
msgstr "<i>Před spuštěním <b>%s</b> se přesvědčte, že je váš systém plně aktualizován</i>."

#: ../akm:435
#, sh-printf-format
msgid "Column headers:"
msgstr "Záhlaví sloupců:"

#: ../akm:436
#, sh-printf-format
msgid "    Choose       Checkboxes for installing/uninstalling kernel packages."
msgstr "    Vybrat          Zaškrtávací políčka pro instalaci/odinstalaci balíčků jader."

#: ../akm:437
#, sh-printf-format
msgid "                 The installed packages are checked at start."
msgstr "                    Nainstalované balíčky jsou kontrolovány při spuštění."

#: ../akm:438
#, sh-printf-format
msgid "    PkgName      Kernel package name."
msgstr "    Název balíčku   Název balíčku jádra."

#: ../akm:439
#, sh-printf-format
msgid "    Installed    Installed kernel package versions."
msgstr "    Nainstalováno   Nainstalované verze balíčku jádra."

#: ../akm:440
#, sh-printf-format
msgid "                 The currently running kernel is printed in italics."
msgstr "                    Aktuálně používané jádro je zobrazeno kurzívou."

#: ../akm:441
#, sh-printf-format
msgid "                 The latest kernel.org version is printed in bold."
msgstr "                    Nejnovější verze na kernel.org je zobrazena tučně."

#: ../akm:442
#, sh-printf-format
msgid "    Stable       Versions available from the stable repos."
msgstr "    Stabilní        Verze dostupné ze stabilních repozitářů."

#: ../akm:443
#, sh-printf-format
msgid "    Testing      Versions available from the testing repos."
msgstr "    Testovací       Verze dostupné z testovacích repozitářů."

#: ../akm:444
#, sh-printf-format
msgid "    %s Kernel category at kernel.org."
msgstr "    %s  Kategorie jádra na kernel.org."

#: ../akm:445
#, sh-printf-format
msgid "    %s  Latest version announced at kernel.org."
msgstr "    %s      Nejnovější verze ohlášená na kernel.org."

#: ../akm:448
#, sh-printf-format
msgid "Your currently used repo (Stable or Testing) is printed in italics (see also /etc/pacman.conf)."
msgstr ""
"Aktuálně používaný repozitář (stabilní nebo testovací) je zobrazen kurzívou (více viz /etc/pacman.conf)."

#: ../akm:449
#, sh-printf-format
msgid "Marking <b>%s</b> means: info not available."
msgstr "Značka <b>%s</b> znamená: informace není k dispozici."

#: ../akm:450
#, sh-printf-format
msgid "See file <tt>/etc/akm.conf</tt> for configuration details."
msgstr "Podrobné informace o nastavení viz <tt>/etc/akm.conf</tt>."

