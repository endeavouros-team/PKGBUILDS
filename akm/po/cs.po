#, sh-printf-format
msgid "Kernel category at kernel.org"
msgstr "Kategorie jádra na kernel.org"

#: ../akm:192
#, sh-printf-format
msgid "Latest version announced at kernel.org"
msgstr "Nejnovější verze ohlášená na kernel.org"

#: ../akm:242
#, sh-printf-format
msgid "Sorry, package 'eos-bash-shared' is not installed."
msgstr "Balíček 'eos-bash-shared' není nainstalován."

#: ../akm:263
#, sh-printf-format
msgid "==> Config file %s read."
msgstr "==> Soubor nastavení %s načten."

#: ../akm:271
#, sh-printf-format
msgid "AKM message"
msgstr "AKM - zpráva"

#: ../akm:293
#, sh-printf-format
msgid "Usage: %s [options]"
msgstr "Použití: %s [možnosti]"

#: ../akm:294
#, sh-printf-format
msgid "options:"
msgstr "možnosti:"

#: ../akm:295
#, sh-printf-format
msgid "    --connect-header      Make kernel and header package go together at install or uninstall."
msgstr ""
"   --connect-header      Při instalaci nebo odinstalaci zpracovávat balíčky jádra a hlaviček společně."

#: ../akm:296
#, sh-printf-format
msgid ""
"    --scroll              Enable scrolling in the kernel info window. Useful if additional kernels are "
"available."
msgstr ""
"   --scroll              Povolit rolování v okně informací o jádrech. Užitečné pokud jsou dostupná "
"dodatečná jádra."

#: ../akm:297
#, sh-printf-format
msgid ""
"    --small               Make the akm window smaller, meant for helping with small displays at 1366x768 "
"resolution."
msgstr ""
"   --small               Použít menší okno, určeno pro použití na malých displejích s rozlišením 1366x768."

#: ../akm:298
#, sh-printf-format
msgid "    --quiet | -q          Be less verbose."
msgstr "   --quiet | -q          Produkovat méně podrobný výstup."

#: ../akm:299
#, sh-printf-format
msgid "    --no-progress         Don't show the progress window."
msgstr "   --no-progress         Nezobrazovat okno s průběhem."

#: ../akm:300
#, sh-printf-format
msgid "    --help | -h           This help."
msgstr "   --help | -h           Tato nápověda."

#: ../akm:312
#, sh-printf-format
msgid "unsupported option '%s'"
msgstr "nepodporovaná možnost ‚%s’"

#: ../akm:313
#, sh-printf-format
msgid "unsupported parameter '%s'"
msgstr "nepodporovaný parametr ‚%s’"

#: ../akm:397
#, sh-printf-format
msgid "==> Info: detecting available kernel packages."
msgstr "==> Informace: zjišťování dostupných balíčků jádra."

