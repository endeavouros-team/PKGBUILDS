msgid "Internal error, cannot determine the running kernel."
msgstr "Interní chyba, nelze určit aktuálně používané jádro."

#: ../akm:69
#, sh-printf-format
msgid ""
"Installed kernel package versions.&#10;The currently running kernel is in <i>italics</i>.&#10;A <b>bolded</"
"b> string means the latest K.o. version."
msgstr ""
"Nainstalované verze balíčku jádra.&#10;Aktuálně používané jádro zobrazeno <i>kurzívou</i>.&#10;<b>Tučně</b> "
"je zobrazena nejnovější dostupná verze na kernel.org."

